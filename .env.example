# Environment Variables Template

# ============================================================================
# COPY THIS FILE AS .env.local AND UPDATE WITH YOUR VALUES
# NEVER COMMIT .env.local TO GIT - ADD TO .gitignore
# ============================================================================

# ============ DATABASE CONFIGURATION ============

# PostgreSQL (RECOMMENDED for production)
DATABASE_URL="postgresql://structura_user:your_secure_password@localhost:5432/structura_db"

# For development with SQLite (avoid in production)
# DATABASE_URL="file:./dev.db"

# Firebase (Alternative option)
# NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project_id"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_bucket.appspot.com"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
# NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"
# FIREBASE_ADMIN_SDK_KEY="path/to/serviceAccountKey.json"

# ============ AUTHENTICATION SECRETS ============

# JWT Secret - CHANGE THIS! Minimum 32 characters, use random string
JWT_SECRET="change_this_to_a_random_minimum_32_character_secret_key_12345678"

# Session Secret - CHANGE THIS! Minimum 32 characters, use random string
SESSION_SECRET="another_random_minimum_32_character_session_secret_key_abcdefghijk"

# ============ SERVER CONFIGURATION ============

# Node environment
NODE_ENV="development"

# API Base URL
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Vercel deployment
# VERCEL_URL="your-app.vercel.app"

# ============ SESSION CONFIGURATION ============

# Remember Me token duration in days
REMEMBER_ME_DURATION_DAYS="30"

# ============ OPTIONAL: FILE UPLOAD ============

# AWS S3 (for portfolio images)
# AWS_ACCESS_KEY_ID="your_access_key"
# AWS_SECRET_ACCESS_KEY="your_secret_key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="structura-files"

# Cloudinary (alternative)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
# CLOUDINARY_API_KEY="your_api_key"
# CLOUDINARY_API_SECRET="your_api_secret"

# ============ OPTIONAL: EMAIL NOTIFICATIONS ============

# SendGrid
# SENDGRID_API_KEY="your_api_key"
# SENDGRID_FROM_EMAIL="noreply@structura.com"

# Mailgun
# MAILGUN_API_KEY="your_api_key"
# MAILGUN_DOMAIN="mg.structura.com"

# ============ OPTIONAL: PAYMENT PROCESSING ============

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Razorpay
# NEXT_PUBLIC_RAZORPAY_KEY_ID="your_key_id"
# RAZORPAY_KEY_SECRET="your_key_secret"

# ============ OPTIONAL: ANALYTICS & MONITORING ============

# Sentry (Error tracking)
# NEXT_PUBLIC_SENTRY_DSN="your_dsn"

# Google Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ============ OPTIONAL: API KEYS & SERVICES ============

# Google Maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_api_key"

# Mapbox
# NEXT_PUBLIC_MAPBOX_TOKEN="your_token"

# ============ DEVELOPMENT ONLY ============

# Enable debug logging
# DEBUG="true"

# Mock data (testing)
# USE_MOCK_DATA="false"

# ============================================================================
# INSTRUCTIONS:
# ============================================================================

# 1. Copy this file to .env.local
# 2. Update all "change_this" values
# 3. For random secrets, use: 
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Never commit .env.local to git
# 5. Add .env.local to .gitignore (important!)
# 6. Restart dev server after changes

# ============================================================================
# GETTING STARTED:
# ============================================================================

# PostgreSQL Setup:
# 1. Install PostgreSQL
# 2. Create database: createdb structura_db
# 3. Create user: CREATE USER structura_user WITH PASSWORD 'password';
# 4. Grant permissions: GRANT ALL ON DATABASE structura_db TO structura_user;
# 5. Update DATABASE_URL with your credentials
# 6. Run: npx prisma migrate dev --name init

# Firebase Setup:
# 1. Go to firebase.google.com
# 2. Create project
# 3. Enable Firestore
# 4. Enable Authentication
# 5. Download config
# 6. Fill Firebase environment variables

# Development Server:
# npm run dev    # Start dev server
# npm run build  # Create production build
# npm start      # Run production build

# ============================================================================
